generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Member {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  username      String
  password      String
  gender        Gender         @default(OTHER)
  role          Role           @default(USER)
  address       String?
  avatar        String?
  createdAt     DateTime       @default(now())
  isActive      Boolean        @default(true)
  phone         String?
  updatedAt     DateTime?      @updatedAt
  Borrows       Borrowed[]
  fine          Fine[]
  refreshTokens RefreshToken[]
  reservation   Reservation[]
}

model Book {
  id               Int           @id @default(autoincrement())
  title            String
  author           String
  publication_year String
  categoryId       Int
  status           BookStatus    @default(AVAILABLE)
  imageUrl         String?
  createdAt        DateTime      @default(now())
  description      String?
  isbn             String?       @unique
  updatedAt        DateTime?     @updatedAt
  category         Category      @relation(fields: [categoryId], references: [id])
  Borrows          Borrowed[]
  reservation      Reservation[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @unique
  books Book[]
}

model Borrowed {
  id         Int          @id @default(autoincrement())
  memberId   Int
  bookId     Int
  title      String
  loanDate   DateTime     @default(now())
  returnDate DateTime?
  dueDate    DateTime?
  status     BorrowStatus @default(BORROWED)
  fineAmount Float        @default(0)
  createdAt  DateTime     @default(now())

  book       Book   @relation(fields: [bookId], references: [id])
  member     Member @relation(fields: [memberId], references: [id])
  fine       Fine[]

  @@index([memberId])
  @@index([bookId])
}

model Reservation {
  id         Int               @id @default(autoincrement())
  memberId   Int
  bookId     Int
  title      String
  status     ReservationStatus @default(PENDING)
  reservedAt DateTime          @default(now())
  expiresAt  DateTime

  book   Book   @relation(fields: [bookId], references: [id])
  member Member @relation(fields: [memberId], references: [id])
}

model Fine {
  id        Int      @id @default(autoincrement())
  memberId  Int
  borrowId  Int
  amount    Float
  paid      Boolean  @default(false)
  createdAt DateTime @default(now())
  borrow    Borrowed @relation(fields: [borrowId], references: [id])
  member    Member   @relation(fields: [memberId], references: [id])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String
  memberId  Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

enum ReservationStatus {
  PENDING
  READY
  CANCELLED
  COMPLETED 
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Role {
  ADMIN
  USER
}

enum BorrowStatus {
  BORROWED
  RETURNED
  OVERDUE
  PENDING
}

enum BookStatus {
  BORROWED
  AVAILABLE
}
